# API Keys - Gere com: node -e "const crypto = require('crypto'); console.log('pk_' + crypto.randomBytes(24).toString('hex'));"
BOT_API_KEY=pk_generate_key_here
ADMIN_API_KEYS=pk_generate_key_here

# CORS
CORS_ORIGIN=http://localhost:3000
